# ── Required ──────────────────────────────────────────────────────
# Turso (libSQL) database. Create a free database at https://turso.tech
# then run `turso db show <name>` and `turso db tokens create <name>`.
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Long, random string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# ── Recommended in production ────────────────────────────────────
# Marks the runtime as production so auth cookies are set with the
# Secure flag. Set this explicitly in your Railway service variables
# (unlike Vercel, Railway does not set this for you automatically).
NODE_ENV=production

# Railway sets PORT automatically at deploy time — you do not need to
# set this yourself. It's only useful for pinning a port in local dev.
# PORT=3000

# ── Optional ──────────────────────────────────────────────────────
# Set to "false" to disable automatic demo category/product seeding
# on a brand new (empty) database.
# SEED_DEMO_DATA=true

# Restrict CORS to a specific origin instead of "*".
# CORS_ORIGIN=https://your-domain.up.railway.app

# Enables durable image uploads via Vercel Blob storage (works fine from
# any host, including Railway — it's just an HTTP API call). Without
# this, uploaded images are stored as inline data URIs on the product
# record, which works out of the box but is less efficient for many/large
# images. Create a Blob store at https://vercel.com/storage/blob to get
# this token.
# BLOB_READ_WRITE_TOKEN=
